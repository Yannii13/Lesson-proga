class Vampire:
    def __init__(self, name, bloodlust):
        # Приватные атрибуты
        self.__name = name
        self.__bloodlust = bloodlust


    def get_bloodlust(self):#Геттер
        return self.__bloodlust

    def set_bloodlust(self, value):#Сеттер
        if 0 <= value <= 100: #Изм уровень жажды
            self.__bloodlust = value
        else:
            print("Ошибка: уровень жажды крови должен быть от 0 до 100")
vampire = Vampire("Дракула", 50) #Созд объект вампира
print(f"Текущий уровень жажды: {vampire.get_bloodlust()}")
print("Устанавливем 75...")#коррект знач
vampire.set_bloodlust(75)
print(f"Уровень жажды после изменения: {vampire.get_bloodlust()}")
print("Устанавливем 150...")#некоррект знач
vampire.set_bloodlust(150)
print(f"Уровень жажды остался: {vampire.get_bloodlust()}")
print("Устанавливаем -10...")#отриц знач
vampire.set_bloodlust(-10)
print(f"Уровень жажды остался: {vampire.get_bloodlust()}")
